     1                                  ; XPSL NTFS stage1
     2                                  ;
     3                                  ; One-sector real-mode loader for the current synthetic NTFS test image.
     4                                  ; It derives $MFT from the BPB, reads root MFT record 5, finds XPSLDR in the
     5                                  ; resident root INDEX_ROOT, reads that file record, copies resident $DATA to
     6                                  ; 0000:8000, and jumps to it.
     7                                  
     8                                  bits 16
     9                                  org 0x7C00
    10                                  
    11                                  LOAD_ADDR       equ 0x8000
    12                                  BUF             equ 0x9000
    13                                  REC_SECTORS     equ 2
    14                                  ROOT_RECNO      equ 5
    15                                  ATTR_INDEX_ROOT equ 0x90
    16                                  ATTR_DATA       equ 0x80
    17                                  
    18                                  start:
    19 00000000 EB52                            jmp     short boot
    20 00000002 90                              nop
    21                                  
    22 00000003 4E54465320202020        oem_id: db 'NTFS    '
    23 0000000B 0002                    bytes_per_sector:    dw 512
    24 0000000D 08                      sectors_per_cluster: db 8
    25 0000000E 0000                    reserved:            dw 0
    26 00000010 000000                  zero0:               db 0, 0, 0
    27 00000013 0000                    unused0:             dw 0
    28 00000015 F8                      media:               db 0xF8
    29 00000016 0000                    zero1:               dw 0
    30 00000018 3F00                    spt:                 dw 63
    31 0000001A FF00                    heads:               dw 255
    32 0000001C 00080000                hidden_sectors:      dd 2048
    33 00000020 00000000                unused1:             dd 0
    34 00000024 00000000                unused2:             dd 0
    35 00000028 0080000000000000        total_sectors:       dq 32768
    36 00000030 0400000000000000        mft_lcn:             dq 4
    37 00000038 0800000000000000        mft_mirror_lcn:      dq 8
    38 00000040 F6                      clusters_per_frs:    db 0xF6
    39 00000041 000000                  rsv0:                db 0, 0, 0
    40 00000044 01                      clusters_per_index:  db 1
    41 00000045 000000                  rsv1:                db 0, 0, 0
    42 00000048 545345544C535058        serial:              dq 0x5850534C54455354
    43 00000050 00000000                checksum:            dd 0
    44                                  
    45                                  boot:
    46 00000054 FA                              cli
    47 00000055 31C0                            xor     ax, ax
    48 00000057 8ED8                            mov     ds, ax
    49 00000059 8EC0                            mov     es, ax
    50 0000005B 8ED0                            mov     ss, ax
    51 0000005D BC007C                          mov     sp, 0x7C00
    52 00000060 FB                              sti
    53 00000061 FC                              cld
    54                                  
    55 00000062 8816[CB01]                      mov     [drive], dl
    56 00000066 B058                            mov     al, 'X'
    57 00000068 E85601                          call    putc
    58                                  
    59 0000006B E86000                          call    calc_mft_lba
    60                                  
    61 0000006E B80500                          mov     ax, ROOT_RECNO
    62 00000071 E87200                          call    read_mft_record
    63 00000074 724A                            jc      die_disk
    64 00000076 66813E009046494C45              cmp     dword [BUF], 'FILE'
    65 0000007F 7546                            jne     die_fmt
    66 00000081 B043                            mov     al, 'C'
    67 00000083 E83B01                          call    putc
    68                                  
    69 00000086 E88D00                          call    find_xpsldr_in_root
    70 00000089 723C                            jc      die_fmt
    71 0000008B B044                            mov     al, 'D'
    72 0000008D E83101                          call    putc
    73                                  
    74 00000090 A1[D001]                        mov     ax, [file_recno]
    75 00000093 E85000                          call    read_mft_record
    76 00000096 7228                            jc      die_disk
    77 00000098 B045                            mov     al, 'E'
    78 0000009A E82401                          call    putc
    79 0000009D 66813E009046494C45              cmp     dword [BUF], 'FILE'
    80 000000A6 751F                            jne     die_fmt
    81 000000A8 B046                            mov     al, 'F'
    82 000000AA E81401                          call    putc
    83                                  
    84 000000AD E8CB00                          call    load_resident_data
    85 000000B0 7215                            jc      die_fmt
    86 000000B2 B047                            mov     al, 'G'
    87 000000B4 E80A01                          call    putc
    88                                  
    89 000000B7 8A16[CB01]                      mov     dl, [drive]
    90 000000BB EA00800000                      jmp     0:LOAD_ADDR
    91                                  
    92                                  die_disk:
    93 000000C0 B044                            mov     al, 'D'
    94 000000C2 E8FC00                          call    putc
    95 000000C5 EB05                            jmp     halt_msg
    96                                  die_fmt:
    97 000000C7 B04E                            mov     al, 'N'
    98 000000C9 E8F500                          call    putc
    99                                  halt_msg:
   100                                  .halt:
   101 000000CC EBFE                            jmp     .halt
   102                                  
   103                                  calc_mft_lba:
   104 000000CE 6631C0                          xor     eax, eax
   105 000000D1 A0[0D00]                        mov     al, [sectors_per_cluster]
   106 000000D4 668B1E[3000]                    mov     ebx, [mft_lcn]
   107 000000D9 66F7E3                          mul     ebx
   108 000000DC 660306[1C00]                    add     eax, [hidden_sectors]
   109 000000E1 66A3[CC01]                      mov     [mft_lba], eax
   110 000000E5 C3                              ret
   111                                  
   112                                  ; AX = MFT record number. Reads 1024 bytes to BUF.
   113                                  read_mft_record:
   114 000000E6 50                              push    ax
   115 000000E7 6631C0                          xor     eax, eax
   116 000000EA 58                              pop     ax
   117 000000EB 66D1E0                          shl     eax, 1
   118 000000EE 660306[CC01]                    add     eax, [mft_lba]
   119 000000F3 66A3[DA01]                      mov     [dap_lba], eax
   120 000000F7 6631C0                          xor     eax, eax
   121 000000FA 66A3[DE01]                      mov     [dap_lba + 4], eax
   122 000000FE C706[D401]0200                  mov     word [dap_count], REC_SECTORS
   123 00000104 C706[D601]0090                  mov     word [dap_off], BUF
   124 0000010A BE[D201]                        mov     si, dap
   125 0000010D B442                            mov     ah, 0x42
   126 0000010F 8A16[CB01]                      mov     dl, [drive]
   127 00000113 CD13                            int     0x13
   128 00000115 C3                              ret
   129                                  
   130                                  find_xpsldr_in_root:
   131 00000116 8B1E1490                        mov     bx, [BUF + 0x14]       ; first attribute offset
   132                                  .attr:
   133 0000011A 6683BF0090FF                    cmp     dword [BUF + bx], 0xFFFFFFFF
   134 00000120 7457                            je      .fail
   135 00000122 6681BF009090000000              cmp     dword [BUF + bx], ATTR_INDEX_ROOT
   136 0000012B 7406                            je      .index
   137 0000012D 039F0490                        add     bx, [BUF + bx + 4]
   138 00000131 EBE7                            jmp     .attr
   139                                  .index:
   140 00000133 89DE                            mov     si, bx
   141 00000135 03B71490                        add     si, [BUF + bx + 0x14]  ; resident value
   142 00000139 81C60090                        add     si, BUF
   143 0000013D 89F7                            mov     di, si
   144 0000013F 83C710                          add     di, 16                 ; INDEX_HEADER
   145 00000142 033D                            add     di, [di]               ; first index entry
   146                                  .entry:
   147 00000144 837D0800                        cmp     word [di + 8], 0
   148 00000148 742F                            je      .fail
   149 0000014A F7450C0200                      test    word [di + 12], 2      ; INDEX_ENTRY_END
   150 0000014F 7528                            jnz     .fail
   151 00000151 807D5006                        cmp     byte [di + 0x50], 6
   152 00000155 751D                            jne     .next
   153 00000157 56                              push    si
   154 00000158 8D7552                          lea     si, [di + 0x52]
   155 0000015B BB[E201]                        mov     bx, name_u16
   156 0000015E B90600                          mov     cx, 6
   157                                  .cmp:
   158 00000161 AD                              lodsw
   159 00000162 3B07                            cmp     ax, [bx]
   160 00000164 750D                            jne     .no
   161 00000166 83C302                          add     bx, 2
   162 00000169 E2F6                            loop    .cmp
   163 0000016B 5E                              pop     si
   164 0000016C 8B05                            mov     ax, [di]               ; low word of file reference
   165 0000016E A3[D001]                        mov     [file_recno], ax
   166 00000171 F8                              clc
   167 00000172 C3                              ret
   168                                  .no:
   169 00000173 5E                              pop     si
   170                                  .next:
   171 00000174 037D08                          add     di, [di + 8]
   172 00000177 EBCB                            jmp     .entry
   173                                  .fail:
   174 00000179 F9                              stc
   175 0000017A C3                              ret
   176                                  
   177                                  load_resident_data:
   178 0000017B 8B1E1490                        mov     bx, [BUF + 0x14]
   179                                  .attr:
   180 0000017F 6683BF0090FF                    cmp     dword [BUF + bx], 0xFFFFFFFF
   181 00000185 742D                            je      .fail
   182 00000187 6681BF009080000000              cmp     dword [BUF + bx], ATTR_DATA
   183 00000190 7406                            je      .data
   184 00000192 039F0490                        add     bx, [BUF + bx + 4]
   185 00000196 EBE7                            jmp     .attr
   186                                  .data:
   187 00000198 80BF089000                      cmp     byte [BUF + bx + 8], 0
   188 0000019D 7515                            jne     .fail
   189 0000019F 8B8F1090                        mov     cx, [BUF + bx + 0x10]  ; resident value length
   190 000001A3 89DE                            mov     si, bx
   191 000001A5 03B71490                        add     si, [BUF + bx + 0x14]  ; resident value offset
   192 000001A9 81C60090                        add     si, BUF
   193 000001AD BF0080                          mov     di, LOAD_ADDR
   194 000001B0 F3A4                            rep     movsb
   195 000001B2 F8                              clc
   196 000001B3 C3                              ret
   197                                  .fail:
   198 000001B4 F9                              stc
   199 000001B5 C3                              ret
   200                                  
   201                                  puts:
   202 000001B6 AC                              lodsb
   203 000001B7 84C0                            test    al, al
   204 000001B9 7405                            jz      .done
   205 000001BB E80300                          call    putc
   206 000001BE EBF6                            jmp     puts
   207                                  .done:
   208 000001C0 C3                              ret
   209                                  
   210                                  putc:
   211 000001C1 53                              push    bx
   212 000001C2 B40E                            mov     ah, 0x0E
   213 000001C4 BB0700                          mov     bx, 0x0007
   214 000001C7 CD10                            int     0x10
   215 000001C9 5B                              pop     bx
   216 000001CA C3                              ret
   217                                  
   218 000001CB 00                      drive      db 0
   219 000001CC 00000000                mft_lba    dd 0
   220 000001D0 0000                    file_recno dw 0
   221                                  
   222                                  dap:
   223 000001D2 10                              db 16
   224 000001D3 00                              db 0
   225                                  dap_count:
   226 000001D4 0200                            dw REC_SECTORS
   227                                  dap_off:
   228 000001D6 0090                            dw BUF
   229 000001D8 0000                            dw 0
   230                                  dap_lba:
   231 000001DA 0000000000000000                dq 0
   232                                  
